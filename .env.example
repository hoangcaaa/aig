# =============================================================================
# AIG — Environment Variables Template
# Copy this file to .env.local (frontend) and fill in all values.
# NEVER commit real keys to version control.
# =============================================================================

# ---------------- RPC Endpoints ----------------
BSC_TESTNET_RPC_URL=
ARC_TESTNET_RPC_URL=

# ---------------- Arc Chain ----------------
ARC_CHAIN_ID=

# ---------------- CCTP Contracts ----------------
CCTP_TOKEN_MESSENGER_BSC=
CCTP_MESSAGE_TRANSMITTER_ARC=
USDC_ADDRESS_BSC_TESTNET=
USDC_ADDRESS_ARC_TESTNET=

# ---------------- CCTP Config ----------------
CIRCLE_ATTESTATION_API=https://iris-api-sandbox.circle.com/attestations
ARC_CCTP_DOMAIN_ID=7

# ---------------- Bridge Mode ----------------
# CCTP = primary path | ADMIN_RELAY = fallback path (Domain 7 NO-GO)
BRIDGE_MODE=CCTP

# ---------------- Admin Relay (fallback only) ----------------
AIG_POOL_WALLET_ADDRESS=
AIG_ADMIN_WALLET_PRIVATE_KEY=
AIG_ADMIN_WALLET_ADDRESS=

# ---------------- PancakeSwap V3 ----------------
PANCAKESWAP_V3_ROUTER_BSC=
PANCAKESWAP_V3_QUOTER_BSC=
WBNB_ADDRESS_BSC=0xae13d989daC2f0dEbFf460aC112a837C89BAa7cd

# ---------------- SwapRouter (set after Phase 5 deploy) ----------------
SWAP_ROUTER_ADDRESS_BSC=
NEXT_PUBLIC_SWAP_ROUTER_ADDRESS_BSC=

# ---------------- Supabase ----------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------- Frontend RPC (client-side) ----------------
NEXT_PUBLIC_BSC_TESTNET_RPC_URL=

# ---------------- Contract Deployment ----------------
WBNB_ADDRESS_BSC_TESTNET=0xae13d989daC2f0dEbFf460aC112a837C89BAa7cd
AIG_REVENUE_POOL_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# ---------------- Test Key (smoke test only — testnet funds only) ----------------
TEST_PRIVATE_KEY=
